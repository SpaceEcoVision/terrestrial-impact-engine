# ============================================================================
# TERRESTRIAL IMPACT ENGINE - ENVIRONMENT CONFIGURATION
# ============================================================================
# Copy this file to .env and configure your settings
# NEVER commit .env to version control!

# ----------------------------------------------------------------------------
# ENVIRONMENT SETTINGS
# ----------------------------------------------------------------------------
# Options: development, staging, production
# In production mode, mock data will raise exceptions instead of returning fake results
ENVIRONMENT=development

# Enable/disable debug logging
DEBUG=True

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# ----------------------------------------------------------------------------
# API ENDPOINTS
# ----------------------------------------------------------------------------
# Launch cadence comes from Launch Library 2 (free, no key) via a committed
# snapshot in reference/launch_cadence.json. Refresh with:
#   python -m managers.launch_manager --refresh

# API Rate Limiting
API_REQUEST_DELAY=0.5
API_MAX_RETRIES=3
API_TIMEOUT=30

# ----------------------------------------------------------------------------
# DATA DIRECTORIES
# ----------------------------------------------------------------------------
# Input satellite data directory
SATELLITE_DATA_DIR=./data

# Output directory for analysis results
OUTPUT_DIR=./data

# Logs directory
LOGS_DIR=./logs

# ----------------------------------------------------------------------------
# ANALYSIS SETTINGS
# ----------------------------------------------------------------------------
# NDBI threshold for built-up area detection (0.0 to 1.0)
NDBI_THRESHOLD=0.2

# Cloud masking - SCL values to mask (comma-separated)
# 3=shadows, 8=med cloud, 9=high cloud, 10=cirrus, 11=snow
CLOUD_MASK_VALUES=3,8,9,10,11

# Default country for analysis
DEFAULT_COUNTRY_CODE=USA

# Maximum years of historical data to fetch
MAX_YEARS_HISTORY=10

# ----------------------------------------------------------------------------
# MOCK DATA SETTINGS
# ----------------------------------------------------------------------------
# Allow mock data fallback when satellite files are missing (development only)
ALLOW_MOCK_DATA=True

# Mock data values for different regions (JSON format or leave default)
# Format: {"region_name": construction_index_percentage}
MOCK_DATA_VALUES={"Starbase_Boca_Chica": 18.5, "Kennedy_Space_Center": 32.1, "Vandenberg": 12.3, "Spaceport_America": 9.4}

# ----------------------------------------------------------------------------
# STATISTICAL SETTINGS
# ----------------------------------------------------------------------------
# Correlation thresholds for hypothesis testing
CORRELATION_STRONG_THRESHOLD=0.6
CORRELATION_WEAK_THRESHOLD=0.2

# Minimum sample size for valid correlation
MIN_SAMPLE_SIZE=3

# ----------------------------------------------------------------------------
# OPTIONAL: ADVANCED SETTINGS
# ----------------------------------------------------------------------------
# Rasterio options
RASTERIO_ENV_GDAL_CACHEMAX=512
RASTERIO_ENV_GDAL_DISABLE_READDIR_ON_OPEN=TRUE

# Async settings
ASYNC_CONCURRENT_REQUESTS=5

# Frontend output format
OUTPUT_FORMAT=json
OUTPUT_INDENT=2

SENTINEL_CLIENT_ID=paste_your_client_id_here
SENTINEL_CLIENT_SECRET=paste_your_client_secret_here

# Optional: extra path to copy the output JSON to (e.g. for a dashboard). Leave blank to skip.
DASHBOARD_PATH=
# ----------------------------------------------------------------------------
# OPTIONAL: AUTHENTICATION (if APIs require keys in future)
# ----------------------------------------------------------------------------
# Uncomment and add if APIs start requiring authentication

# ----------------------------------------------------------------------------
# OPTIONAL: DATABASE (if persistence is added)
# ----------------------------------------------------------------------------
# DATABASE_URL=postgresql://user:pass@localhost:5432/remit_sky
# REDIS_URL=redis://localhost:6379/0

# ----------------------------------------------------------------------------
# SENTRY ERROR TRACKING (optional)
# ----------------------------------------------------------------------------
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
# SENTRY_ENVIRONMENT=development
